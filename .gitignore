# Proprietary vendor app — never commit or redistribute
moldsign2412unbundled/

# Per-machine TLS serving cert+key (Daemon Phase D). Default location is under
# ~/Library, but guard against a repo-local --tls-dir ever committing key material.
tls/
serving-cert.pem
serving-key.pem

# macOS
.DS_Store

# Build artifacts
bin/
dist/

# Java DSS helper build outputs (the pom + sources are committed, not the jar)
java/dss-helper/target/

# Local command output
inspect-out/
sign-raw-out/
sign-out/

# Reference signature samples — contain personal cert data, never commit
signed-samples/

# Protocol-recon capture artifacts — embed a real qualified cert + personal data.
# PROTOCOL.md is the sanitized deliverable; the raw captures never get committed.
*.har
*.saz
*.rar
moldsign-recon-*
RESULT-*.bin
test.pdf
# Detached-original fixture for XAdES verify integration tests (not committed).
test.txt

# Agent worktrees (transient)
.claude/worktrees/
